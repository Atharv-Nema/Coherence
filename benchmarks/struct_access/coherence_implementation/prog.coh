type point = struct {
    x: int;
    y: int;
    z: int;
}

actor Main {
    new create() {
        var p: point = ({x = 1; y = 2; z = 3;}: point);
        // 1e8
        var num_ops: int = 100000000;
        var i: int = 0;
        while(i < num_ops) {
            // Simple operations
            p.x = p.x + 1;
            p.y = (p.x + p.y) % 10;
            p.z = p.z + p.y;
            i = i + 1;
        }
        OUT p.z;
    }
}