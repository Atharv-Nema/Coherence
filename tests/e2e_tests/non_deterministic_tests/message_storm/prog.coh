actor Sink {
    new create() {}
    be send_a() {
        OUT -1;
    }
    be send_b() {
        OUT 1;
    }
}

actor A {
    s_inst: Sink;
    new create(Sink s) {
        s_inst := s;
    }
    be start() {
        var i: int = 0;
        while(i < 10000) {
            s_inst->send_a();
            i = i + 1;
        }
    }
}

actor B {
    s_inst: Sink;
    new create(Sink s) {
        s_inst := s;
    }
    be start() {
        var i: int = 0;
        while(i < 10000) {
            s_inst->send_b();
            i = i + 1;
        }
    }
}

actor Main {
    new create() {
        var sink_inst: Sink = new Sink.create(); 
        var a_inst: A = new A.create(sink_inst);
        var b_inst: B = new B.create(sink_inst);
        a_inst->start();
        b_inst->start();
    }
}